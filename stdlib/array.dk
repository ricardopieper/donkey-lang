struct array<T>:
    length: u64
    base: ptr<T>

impl array<T>:

    def len(self) -> u64:
        return (*self).length

    def __index_ptr__(self, index: u64) -> ptr<T>:
        return &(*self).base[index]

    def __iterator__(self) -> ArrayIterator<T>:
        iterator = ArrayIterator<T>()
        iterator.array = self
        iterator.current = 0
        return iterator

struct ArrayIterator<T>:
    array: ptr<array<T>>
    current: u64

impl ArrayIterator<T>:

    def has_next(self) -> bool:
        return (*self).current < (*(*self).array).length

    def next(self) -> ptr<T>:
        retval = &(*(*self).array)[(*self).current]
        (*self).current = (*self).current + 1
        return retval
